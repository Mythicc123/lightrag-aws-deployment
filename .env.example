# LightRAG Environment Variables
# DO NOT COMMIT THIS FILE
# Copy to .env and fill in real values. All secrets are loaded from SSM Parameter Store at bootstrap time.
# Set these values in AWS SSM Parameter Store under /lightrag/:
#   /lightrag/ANTHROPIC_API_KEY  — Anthropic API key (SecureString)
#   /lightrag/OPENAI_API_KEY     — OpenAI API key (SecureString)
#   /lightrag/LIGHTRAG_API_KEY   — LightRAG built-in auth key (SecureString)

ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
LIGHTRAG_API_KEY=your_lightrag_api_key_here

# LLM models (Anthropic Claude)
MODEL=claude-sonnet-3-7-20250619
MODEL_LIST=claude-haiku-3-5-20250514

# Embedding model (OpenAI text-embedding-3-large)
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=3072

# Server configuration
HOST=0.0.0.0
PORT=9621
